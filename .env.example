APP_NAME=Fiyox School Management System
ENV=dev
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Dev (default): local SQLite
DATABASE_URL=sqlite+aiosqlite:///./school.db
# Prod: Neon / Postgres
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# Nigerian integrations (later phases)
# Paystack: set your secret key to enable online payments, then point your
# Paystack dashboard webhook to https://<your-api-domain>/api/fees/paystack/webhook
PAYSTACK_SECRET_KEY=
TERMII_API_KEY=
TERMII_SENDER_ID=Fiyox
ANTHROPIC_API_KEY=
